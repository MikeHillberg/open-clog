<UserControl
    x:Class="open_clog.GridSplitterEx"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    >
    <Grid>
        <!-- Visible divider line in the center -->
        <Rectangle x:Name="_dividerLine" Fill="#60808080" 
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <!-- Transparent hit target over the full area -->
        <Rectangle x:Name="_splitterRect"
                   Fill="Transparent"
                   PointerEntered="Splitter_PointerEntered"
                   PointerExited="Splitter_PointerExited"
                   PointerPressed="Splitter_PointerPressed"
                   PointerMoved="Splitter_PointerMoved"
                   PointerReleased="Splitter_PointerReleased" />
    </Grid>
</UserControl>
