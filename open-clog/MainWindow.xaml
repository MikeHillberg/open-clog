<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="open_clog.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:open_clog"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenCLog - Session Viewer">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <InfoBar x:Name="NoInstallBar" Grid.Row="0"
                 Title="No OpenClaw install found on this device"
                 Message="OpenClog requires OpenClaw to be installed with at least one agent session."
                 Severity="Warning"
                 IsOpen="False"
                 IsClosable="False"/>

        <!-- Agent and session selectors -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="12,8" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Agent:" VerticalAlignment="Center" FontSize="13" Foreground="Gray"/>
                <ComboBox x:Name="AgentCombo" FontSize="14" FontWeight="SemiBold"
                          SelectionChanged="AgentCombo_SelectionChanged"
                          MinWidth="150"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Session:" VerticalAlignment="Center" FontSize="13" Foreground="Gray"/>
                <ComboBox x:Name="SessionCombo" FontSize="14" FontWeight="SemiBold"
                          SelectionChanged="SessionCombo_SelectionChanged"
                          MinWidth="300"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Iterations list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Turns (most recent on top)" Grid.Row="0" Padding="12,4" FontSize="12" FontWeight="SemiBold" Foreground="Gray"/>
            <ListView x:Name="MessageList"
                      Grid.Row="1"
                      SelectionChanged="MessageList_SelectionChanged"
                      Padding="8">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:UserMessageItem">
                        <StackPanel Padding="4">
                            <TextBlock Text="{x:Bind Timestamp}" />
                            <TextBlock Text="{x:Bind Preview}" FontSize="11" Foreground="Gray"
                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Column="1" Width="1" Background="Gray" Opacity="0.3"/>

        <!-- Detail pane: top list + bottom JSON -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header row with Messages label and token column headers -->
            <Grid Grid.Row="0" Padding="12,4,20,4">
                <TextBlock Text="Messages" FontSize="12" FontWeight="SemiBold" Foreground="Gray"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
                    <TextBlock Text="tokens:" FontSize="10" Foreground="Gray" Margin="0,0,4,0"/><TextBlock Text="in" FontSize="10" Foreground="Gray" Width="60" TextAlignment="Right"/>
                    <TextBlock Text="cache rd" FontSize="10" Foreground="Gray" Width="65" TextAlignment="Right"/>
                    <TextBlock Text="cache wr" FontSize="10" Foreground="Gray" Width="65" TextAlignment="Right"/>
                    <TextBlock Text="out" FontSize="10" Foreground="Gray" Width="60" TextAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- Top: subtree entry list -->
            <ListView x:Name="DetailList"
                      Grid.Row="1"
                      Padding="8"
                      SelectionChanged="DetailList_SelectionChanged"
                      DoubleTapped="DetailList_DoubleTapped">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:DetailLineItem">
                        <Border Background="{x:Bind RowBackground}" Padding="4" CornerRadius="4">
                        <Grid>
                            <StackPanel>
                                <TextBlock FontSize="12" Text="{x:Bind TypeAndId}"/>
                                <TextBlock Text="{x:Bind ContentPreview}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="3"
                                           Visibility="{x:Bind HasContent}"/>
                                <TextBlock Text="{x:Bind ToolCallPreview}"
                                           FontSize="11" Foreground="CornflowerBlue"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="10"
                                           Visibility="{x:Bind HasToolCall}"/>
                                <TextBlock Text="{x:Bind ThinkingPreview}"
                                           FontSize="11" Foreground="MediumPurple"
                                           FontStyle="Italic"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2"
                                           Visibility="{x:Bind HasThinking}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="0">
                                <TextBlock Text="{x:Bind TokenIn}" FontSize="11" Width="60" TextAlignment="Right" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind TokenCacheRead}" FontSize="11" Width="65" TextAlignment="Right" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind TokenCacheWrite}" FontSize="11" Width="65" TextAlignment="Right" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind TokenOut}" FontSize="11" Width="60" TextAlignment="Right" Foreground="Gray"/>
                            </StackPanel>
                        </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="2" Height="1" Background="Gray" Opacity="0.3"/>

            <!-- Bottom: full JSON of selected detail item -->
            <ScrollViewer Grid.Row="3" Padding="12">
                <TextBlock x:Name="DetailJsonText"
                           IsTextSelectionEnabled="True"
                           FontFamily="Cascadia Code,Consolas,Courier New"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Grid>
    </Grid>
    </Grid>
</Window>
