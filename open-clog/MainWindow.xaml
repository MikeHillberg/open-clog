<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="open_clog.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:open_clog"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenCLog - Session Viewer">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <InfoBar x:Name="NoInstallBar" Grid.Row="0"
                 Title="No OpenClaw install found on this device"
                 Message="OpenClog requires OpenClaw to be installed with at least one agent session."
                 Severity="Warning"
                 IsOpen="False"
                 IsClosable="False"/>

        <!-- Agent and session selectors -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="12,8" Spacing="16">
            <ToggleButton x:Name="AutoScrollToggle" IsChecked="True"
                              ToolTipService.ToolTip="Enable for auto-scroll, where the latest turn and latest turn message are always selected. This will automatically be disabled if you click an older turn or message"
                              Click="AutoScrollToggle_Click"
                              VerticalAlignment="Center">
                <SymbolIcon Symbol="Play"/>
            </ToggleButton>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Agent:" VerticalAlignment="Center" FontSize="13" Foreground="Gray"/>
                <ComboBox x:Name="AgentCombo" FontSize="14" FontWeight="SemiBold"
                          SelectionChanged="AgentCombo_SelectionChanged"
                          MinWidth="150"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Session:" VerticalAlignment="Center" FontSize="13" Foreground="Gray" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SessionCombo" FontSize="14" FontWeight="SemiBold"
                          SelectionChanged="SessionCombo_SelectionChanged"
                          MinWidth="300"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SessionIdText" FontSize="11" Foreground="Gray"
                           IsTextSelectionEnabled="True" Margin="0,2,0,0"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Turns list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Turns (most recent on top)" Grid.Row="0" Padding="12,4" FontSize="12" FontWeight="SemiBold" Foreground="Gray"/>
                <ListView x:Name="MessageList"
                          Grid.Row="1"
                          SelectionChanged="MessageList_SelectionChanged"
                          Padding="8">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:UserMessageItem">
                            <StackPanel Padding="4">
                                <TextBlock Text="{x:Bind Timestamp}" />
                                <TextBlock Text="{x:Bind Preview}" FontSize="11" Foreground="Gray"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Vertical splitter (drag to resize turns list) -->
            <local:GridSplitterEx x:Name="VerticalSplitter" Grid.Column="0" Width="6" HorizontalAlignment="Right"/>

            <!-- Detail pane: top list + bottom JSON -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header row with Messages label and token column headers -->
                <Grid Grid.Row="0" Padding="12,4,20,4">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock x:Name="MessagesHeader" Text="Messages" FontSize="12" FontWeight="SemiBold" Foreground="Gray"/>
                        <HyperlinkButton x:Name="ExportLink" Content="[Export," FontSize="11"
                                         Padding="0,0,0,0" IsEnabled="False"
                                         Click="ExportLink_Click"/>
                        <HyperlinkButton x:Name="PromptLink" Content="Prompt]" FontSize="11"
                                         Padding="0,0,0,0" IsEnabled="False" Margin="-4,0,0,0"
                                         Click="PromptLink_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
                        <TextBlock Text="tokens:" FontSize="10" Foreground="Gray" Margin="0,0,4,0"/>
                        <TextBlock Text="in" FontSize="10" Foreground="Gray" Width="60" TextAlignment="Right"/>
                        <TextBlock Text="cache rd" FontSize="10" Foreground="Gray" Width="65" TextAlignment="Right"/>
                        <TextBlock Text="cache wr" FontSize="10" Foreground="Gray" Width="65" TextAlignment="Right"/>
                        <TextBlock Text="out" FontSize="10" Foreground="Gray" Width="60" TextAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <!-- Placeholder when no turn selected -->
                <TextBlock x:Name="NoTurnSelected" Grid.Row="1" 
                           Text="Select a turn to see turn messages"
                           FontStyle="Italic" Foreground="Gray" FontSize="13"
                           Padding="16,12" Visibility="Visible"/>

                <!-- Top: subtree entry list -->
                <ListView x:Name="DetailList"
                          Grid.Row="1"
                          Padding="8"
                          SelectionChanged="DetailList_SelectionChanged"
                          DoubleTapped="DetailList_DoubleTapped">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:DetailLineItem">
                            <Border Background="{x:Bind RowBackground}" Padding="4" CornerRadius="4">
                            <Grid>
                                <StackPanel>
                                    <TextBlock FontSize="12" Text="{x:Bind TypeAndId}"/>
                                    <TextBlock Text="{x:Bind ContentPreview}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="3"
                                               Visibility="{x:Bind HasContent}"/>
                                    <TextBlock Text="{x:Bind ToolCallPreview}"
                                               FontSize="11" Foreground="CornflowerBlue"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="10"
                                               Visibility="{x:Bind HasToolCall}"/>

                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="0">
                                    <TextBlock Text="{x:Bind TokenIn}" FontSize="11" Width="60" TextAlignment="Right" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TokenCacheRead}" FontSize="11" Width="65" TextAlignment="Right" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TokenCacheWrite}" FontSize="11" Width="65" TextAlignment="Right" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TokenOut}" FontSize="11" Width="60" TextAlignment="Right" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Placeholder when no message selected -->
                <TextBlock x:Name="NoMessageSelected" Grid.Row="2"
                           Text="Select a message to see message detail"
                           FontStyle="Italic" Foreground="Gray" FontSize="13"
                           Padding="16,12" Visibility="Visible"/>

                <!-- Bottom: full JSON of selected detail item -->
                <ScrollViewer x:Name="DetailJsonScroller" Grid.Row="2" Padding="12">
                    <TextBlock x:Name="DetailJsonText"
                               IsTextSelectionEnabled="True"
                               FontFamily="Cascadia Code,Consolas,Courier New"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>

                <!-- Horizontal splitter (drag to resize JSON pane) -->
                <local:GridSplitterEx x:Name="HorizontalSplitter" Grid.Row="2" Height="6" VerticalAlignment="Top"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
